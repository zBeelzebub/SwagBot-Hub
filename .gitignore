# SwagBot Hub public repo ignore rules

# Local editor / OS files
.DS_Store
Thumbs.db
desktop.ini
.vscode/
.idea/

# Codex / local workspace files
.agents/
.codex/

# Private readable source files
/SwagBotHub.lua
/SwagBotHub-*.lua
/*source*.lua
/src/
/private/

# Keep the public obfuscated distribution file
!/dist/
!/dist/SwagBotHub.lua

# Private obfuscation outputs / tooling
/*-obfuscated.lua
/*-strong.lua
/luraph-*.lua
/prometheus-*.config.lua

# Private backend files
/swagbot-key-worker.js

# Local SwagBot configs and saved keys
/SwagBotHubConfigs/
/RoxityConfigs/
/chatbot_configs/
*.key
*.token
.env
.env.*

# Lua / build artifacts
luac.out
*.src.rock
*.zip
*.tar.gz

# Roblox files
*.rbxm
*.rbxl
*.rbxmx
sourcemap.json

# Binaries
*.exe
*.dll
*.so
*.dylib
*.out
*.obj
*.o
